{
  "name": "Hugo Development",
  "dockerFile": "Dockerfile.dev",
  "runArgs": [
    "-p", "1313:1313"
  ],
  "mounts": [
    "source=${localWorkspaceFolder}/hugo-theme-academic-cv,target=/app,type=bind"
  ],
  "workingDirectory": "/app",
  "customizations": {
    "vscode": {
      "extensions": [
        "tamasfe.even-better-toml",
        "davidanson.vscode-markdown",
        "saoudrizwan.claude-dev"
      ]
    }
  },
  "postCreateCommand": "cd /app && npm install"
}